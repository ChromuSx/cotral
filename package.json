{
  "name": "cotral",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/shared",
    "packages/server",
    "packages/bot"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "build:shared": "npm run build -w @cotral/shared",
    "build:server": "npm run build -w @cotral/server",
    "build:bot": "npm run build -w @cotral/bot",
    "start:server": "npm run start -w @cotral/server",
    "start:bot": "npm run start -w @cotral/bot",
    "test": "npm run test --workspaces",
    "test:server": "npm run test -w @cotral/server",
    "test:bot": "npm run test -w @cotral/bot"
  }
}
